# Science of Science Research Project - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's already in .gitignore)

# =============================================================================
# API KEYS (Get these from respective services)
# =============================================================================

# OpenAlex API (free key: https://openalex.org/users/me)
# Using an email puts you in the "polite pool" with higher rate limits
RESEARCH_OPENALEX_EMAIL=your@email.com
RESEARCH_OPENALEX_API_KEY=

# Semantic Scholar API (optional, get key: https://www.semanticscholar.org/product/api)
RESEARCH_SEMANTIC_SCHOLAR_API_KEY=

# =============================================================================
# Neo4j Graph Database (required for API server)
# =============================================================================

RESEARCH_NEO4J_URI=bolt://localhost:7687
RESEARCH_NEO4J_USER=neo4j
RESEARCH_NEO4J_PASSWORD=research2026

# =============================================================================
# Paths (relative to project root)
# =============================================================================

RESEARCH_DATA_DIR=data/
RESEARCH_CACHE_DIR=data/cache/

# =============================================================================
# API Server Configuration (scripts/run_api.py)
# =============================================================================

# Optional API key for production deployments (leave empty to disable)
RESEARCH_API_KEY=

# Rate limiting (e.g., "60/minute", "100/hour")
RESEARCH_RATE_LIMIT=60/minute

# CORS origins (comma-separated, "*" for all)
RESEARCH_CORS_ORIGINS=*

# =============================================================================
# Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
RESEARCH_LOG_LEVEL=INFO
