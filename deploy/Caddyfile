# Palimpsest API — Caddy reverse proxy with auto-HTTPS via Let's Encrypt.
#
# Install (Ubuntu 22.04+):
#   sudo apt install -y debian-keyring debian-archive-keyring apt-transport-https
#   curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
#   curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | sudo tee /etc/apt/sources.list.d/caddy-stable.list
#   sudo apt update && sudo apt install -y caddy
#
# Deploy this file:
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile
#   sudo systemctl restart caddy
#
# Required: router port-forwarding 80 + 443 → this host's LAN IP.
# DNS: scigraph.suanlab.com A record → public WAN IP (already configured).

# Global: disable HTTP/3.
# Reason: HTTP/3 runs over UDP/443. The iptime router only forwards
# TCP/80 and TCP/443; UDP/443 is not forwarded. Browsers that respect
# the `alt-svc: h3=":443"` advertisement try QUIC on UDP/443, time out,
# and surface as "Failed to fetch" before falling back to HTTP/2. We
# restrict the listening protocols to h1 + h2 so no `alt-svc` header
# is ever advertised.
{
    servers {
        protocols h1 h2
    }
}

scigraph.suanlab.com {
    # Reverse proxy to local FastAPI on port 8300
    reverse_proxy localhost:8300

    # Allow CORS preflight from the GitHub Pages frontend.
    # FastAPI already sets CORS headers; Caddy passes them through.
    # No additional header manipulation needed.

    # Sensible request log (stderr → journald)
    log {
        output stderr
        format console
        level INFO
    }

    # Compression for JSON responses
    encode gzip zstd

    # Reasonable timeouts for graph queries
    request_body {
        max_size 10MB
    }
}

# Optional: redirect bare suanlab.com/api → scigraph.suanlab.com (for typo-resilience).
# Uncomment if desired.
#
# suanlab.com/api/* {
#     redir https://scigraph.suanlab.com{uri} 308
# }
